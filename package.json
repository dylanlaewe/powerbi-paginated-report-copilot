{
  "name": "powerbi-paginated-report-copilot",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "copilot:generate": "tsx packages/rdl-copilot/src/cli.ts",
    "dev": "pnpm --filter @powerbi-copilot/desktop dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "package:win": "pnpm --filter @powerbi-copilot/desktop package:win",
    "package:win:dir": "pnpm --filter @powerbi-copilot/desktop package:win:dir",
    "setup:electron": "pnpm --filter @powerbi-copilot/desktop exec install-electron",
    "sidecar:inspect": "tsx packages/rdl-copilot/src/inspection-cli.ts",
    "sidecar:cli": "tsx packages/rdl-copilot/src/sidecar-cli-entry.ts",
    "spike:rdl-compatibility-01": "tsx packages/rdl-spike/src/compatibility-cli.ts",
    "spike:rdl-compatibility-02": "tsx packages/rdl-spike/src/candidate02-cli.ts",
    "spike:rdl-compatibility-03": "tsx packages/rdl-spike/src/candidate03-cli.ts",
    "spike:rdl-compatibility-03b": "tsx packages/rdl-spike/src/candidate03b-cli.ts",
    "spike:rdl-compatibility-04": "tsx packages/rdl-spike/src/candidate04-cli.ts",
    "spike:rdl-compatibility-04b": "tsx packages/rdl-spike/src/candidate04b-cli.ts",
    "spike:rdl-compatibility-04c": "tsx packages/rdl-spike/src/candidate04c-cli.ts",
    "spike:rdl-compatibility-05": "tsx packages/rdl-spike/src/candidate05-cli.ts",
    "spike:rdl-compatibility-06": "tsx packages/rdl-spike/src/candidate06-cli.ts",
    "spike:rdl-compatibility-06b": "tsx packages/rdl-spike/src/candidate06b-cli.ts",
    "spike:rdl-forensics": "tsx packages/rdl-spike/src/forensics-cli.ts",
    "spike:rdl-group-forensics": "tsx packages/rdl-spike/src/group-forensics-cli.ts",
    "spike:rdl-grand-total-forensics": "tsx packages/rdl-spike/src/grand-total-forensics-cli.ts",
    "spike:rdl-pagination-forensics": "tsx packages/rdl-spike/src/pagination-forensics-cli.ts",
    "spike:rdl-subtotal-forensics": "tsx packages/rdl-spike/src/subtotal-forensics-cli.ts",
    "spike:rdl-generate": "tsx packages/rdl-spike/src/cli.ts",
    "spike:generate": "tsx packages/pbir-spike/src/cli.ts",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@microsoft/powerbi-report-authoring-cli": "0.1.4",
    "@types/node": "22.19.15",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.8.2",
    "tsx": "4.20.6",
    "typescript": "6.0.2",
    "typescript-eslint": "8.56.1",
    "vitest": "4.1.0"
  }
}
